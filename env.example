# Скопируйте в .env и подставьте свои значения.
PORT=3000
NODE_ENV=development

# Строка подключения MongoDB (не коммитьте с паролем в git).
MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/DB_NAME?authSource=admin

# Для CORS: локальный Vite и/или ваш домен в продакшене (через запятую).
CLIENT_ORIGIN=http://localhost:5173
